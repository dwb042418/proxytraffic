#!/usr/bin/env python3
"""
V2Ray Attack Simulator - Aggressive Traffic Generator
Simulates various V2Ray bypass techniques for testing detection
"""

import os
import sys
import time
import random
import logging
import yaml
import socket
from scapy.all import *

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger('attacker')


class V2RayAttackSimulator:
    """Simulates V2Ray/proxy attack traffic"""

    def __init__(self, config_path='/app/config.yaml'):
        """Initialize attack simulator"""
        logger.info("Initializing V2Ray Attack Simulator...")

        # Load configuration
        with open(config_path, 'r') as f:
            self.config = yaml.safe_load(f)

        self.intensity = self.config['attacker']['intensity']
        self.target_host = self.config['attacker']['target_host']
        self.target_ports = self.config['attacker']['target_ports']
        self.patterns = self.config['attacker']['patterns']

        # Get packets per second based on intensity
        self.pps = self.config['attacker']['pps'][self.intensity]

        # Resolve target IP
        try:
            self.target_ip = socket.gethostbyname(self.target_host)
            logger.info(f"Target resolved: {self.target_host} -> {self.target_ip}")
        except Exception as e:
            logger.error(f"Cannot resolve target: {e}")
            self.target_ip = "172.20.0.10"

        logger.info(f"Attack intensity: {self.intensity} ({self.pps} pps)")
        logger.info(f"Enabled patterns: {[k for k, v in self.patterns.items() if v]}")

        self.running = False
        self.stats = {
            'packets_sent': 0,
            'bytes_sent': 0,
            'attacks': {
                'missing_ua': 0,
                'high_entropy': 0,
                'dns_tunnel': 0,
                'websocket': 0
            }
        }

    def generate_high_entropy_payload(self, size=1024):
        """Generate high entropy encrypted-like payload"""
        # Random bytes simulate encrypted V2Ray traffic
        return bytes(random.randint(0, 255) for _ in range(size))

    def generate_websocket_handshake_no_ua(self, target_port=443):
        """Generate WebSocket handshake WITHOUT User-Agent (V2Ray indicator)"""
        handshake = (
            f"GET / HTTP/1.1\r\n"
            f"Host: {self.target_ip}:{target_port}\r\n"
            f"Upgrade: websocket\r\n"
            f"Connection: Upgrade\r\n"
            f"Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n"
            f"Sec-WebSocket-Version: 13\r\n"
            # MISSING User-Agent header - key V2Ray indicator
            f"\r\n"
        )
        return handshake.encode()

    def attack_missing_user_agent(self):
        """Simulate V2Ray WebSocket without User-Agent"""
        try:
            target_port = random.choice(self.target_ports)

            # Create TCP packet with WebSocket handshake
            payload = self.generate_websocket_handshake_no_ua(target_port)

            packet = IP(dst=self.target_ip) / \
                     TCP(dport=target_port, sport=random.randint(10000, 60000), flags='PA') / \
                     Raw(load=payload)

            send(packet, verbose=0)

            self.stats['packets_sent'] += 1
            self.stats['bytes_sent'] += len(packet)
            self.stats['attacks']['missing_ua'] += 1

            logger.debug(f"Sent WebSocket handshake without User-Agent to {self.target_ip}:{target_port}")

        except Exception as e:
            logger.error(f"Error in missing UA attack: {e}")

    def attack_high_entropy_traffic(self):
        """Simulate encrypted V2Ray traffic with high entropy"""
        try:
            target_port = random.choice(self.target_ports)

            # Generate large encrypted payload
            payload_size = random.randint(512, 2048)
            payload = self.generate_high_entropy_payload(payload_size)

            packet = IP(dst=self.target_ip) / \
                     TCP(dport=target_port, sport=random.randint(10000, 60000), flags='PA') / \
                     Raw(load=payload)

            send(packet, verbose=0)

            self.stats['packets_sent'] += 1
            self.stats['bytes_sent'] += len(packet)
            self.stats['attacks']['high_entropy'] += 1

            logger.debug(f"Sent high entropy payload ({payload_size} bytes)")

        except Exception as e:
            logger.error(f"Error in high entropy attack: {e}")

    def attack_dns_tunneling(self):
        """Simulate DNS tunneling with oversized queries"""
        try:
            # Create DNS query with unusually large payload
            # Normal DNS: 50-100 bytes, Tunneling: 150+ bytes
            subdomain = ''.join(random.choices('abcdefghijklmnopqrstuvwxyz0123456789', k=120))
            domain = f"{subdomain}.v2ray-tunnel.com"

            packet = IP(dst=self.target_ip) / \
                     UDP(dport=53, sport=random.randint(10000, 60000)) / \
                     DNS(rd=1, qd=DNSQR(qname=domain))

            send(packet, verbose=0)

            self.stats['packets_sent'] += 1
            self.stats['bytes_sent'] += len(packet)
            self.stats['attacks']['dns_tunnel'] += 1

            logger.debug(f"Sent DNS tunneling query (size: {len(packet)} bytes)")

        except Exception as e:
            logger.error(f"Error in DNS tunneling attack: {e}")

    def attack_unidirectional_flow(self):
        """Simulate unidirectional download-heavy traffic"""
        try:
            target_port = random.choice(self.target_ports)
            src_port = random.randint(10000, 60000)

            # Send multiple packets in one direction (simulating download)
            for _ in range(10):
                payload_size = random.randint(1200, 1400)  # MTU-sized packets
                payload = self.generate_high_entropy_payload(payload_size)

                packet = IP(dst=self.target_ip) / \
                         TCP(dport=target_port, sport=src_port, flags='A') / \
                         Raw(load=payload)

                send(packet, verbose=0)

                self.stats['packets_sent'] += 1
                self.stats['bytes_sent'] += len(packet)

                time.sleep(0.001)  # Small delay between packets

            logger.debug(f"Sent unidirectional burst (10 packets)")

        except Exception as e:
            logger.error(f"Error in unidirectional attack: {e}")

    def attack_websocket_with_encryption(self):
        """Combine WebSocket + high entropy (advanced V2Ray)"""
        try:
            target_port = random.choice(self.target_ports)

            # WebSocket frame with encrypted payload
            handshake = self.generate_websocket_handshake_no_ua(target_port)

            # Send handshake
            packet1 = IP(dst=self.target_ip) / \
                      TCP(dport=target_port, sport=random.randint(10000, 60000), flags='PA') / \
                      Raw(load=handshake)

            send(packet1, verbose=0)

            # Follow with encrypted data frames
            time.sleep(0.01)

            for _ in range(5):
                ws_payload = self.generate_high_entropy_payload(random.randint(256, 1024))
                packet2 = IP(dst=self.target_ip) / \
                          TCP(dport=target_port, sport=packet1[TCP].sport, flags='PA') / \
                          Raw(load=ws_payload)

                send(packet2, verbose=0)
                self.stats['packets_sent'] += 1
                self.stats['bytes_sent'] += len(packet2)

                time.sleep(0.005)

            self.stats['attacks']['websocket'] += 1

            logger.debug(f"Sent WebSocket + encrypted data")

        except Exception as e:
            logger.error(f"Error in WebSocket attack: {e}")

    def run_attack_cycle(self):
        """Run one attack cycle with all enabled patterns"""

        # Attack 1: Missing User-Agent (if enabled)
        if self.patterns.get('missing_user_agent', False):
            self.attack_missing_user_agent()

        # Attack 2: High entropy traffic (if enabled)
        if self.patterns.get('high_entropy', False):
            self.attack_high_entropy_traffic()

        # Attack 3: DNS tunneling (if enabled)
        if self.patterns.get('dns_tunneling', False):
            self.attack_dns_tunneling()

        # Attack 4: Unidirectional (if enabled)
        if self.patterns.get('unidirectional', False):
            self.attack_unidirectional_flow()

        # Attack 5: WebSocket abuse (if enabled)
        if self.patterns.get('websocket_abuse', False):
            self.attack_websocket_with_encryption()

    def print_statistics(self):
        """Print attack statistics"""
        logger.info("=" * 60)
        logger.info("ATTACK STATISTICS")
        logger.info("=" * 60)
        logger.info(f"Total packets sent: {self.stats['packets_sent']}")
        logger.info(f"Total bytes sent: {self.stats['bytes_sent']:,} ({self.stats['bytes_sent'] / 1024 / 1024:.2f} MB)")
        logger.info(f"Missing UA attacks: {self.stats['attacks']['missing_ua']}")
        logger.info(f"High entropy attacks: {self.stats['attacks']['high_entropy']}")
        logger.info(f"DNS tunneling attacks: {self.stats['attacks']['dns_tunnel']}")
        logger.info(f"WebSocket attacks: {self.stats['attacks']['websocket']}")
        logger.info("=" * 60)

    def start(self):
        """Start attack simulation"""
        logger.info("=" * 60)
        logger.info("STARTING V2RAY ATTACK SIMULATION")
        logger.info("=" * 60)
        logger.info(f"Target: {self.target_ip}")
        logger.info(f"Intensity: {self.intensity} ({self.pps} packets/second)")
        duration_str = 'Infinite' if self.config['attacker']['duration'] == 0 else f"{self.config['attacker']['duration']}s"
        logger.info(f"Duration: {duration_str}")
        logger.info("=" * 60)

        self.running = True
        start_time = time.time()
        duration = self.config['attacker']['duration']

        try:
            while self.running:
                cycle_start = time.time()

                # Run attack cycle
                self.run_attack_cycle()

                # Calculate sleep time to achieve target PPS
                cycle_time = time.time() - cycle_start
                sleep_time = max(0, (1.0 / self.pps) - cycle_time)
                time.sleep(sleep_time)

                # Print stats every 10 seconds
                if int(time.time() - start_time) % 10 == 0 and int(time.time() - start_time) > 0:
                    elapsed = time.time() - start_time
                    pps_actual = self.stats['packets_sent'] / elapsed
                    logger.info(f"Running... {int(elapsed)}s | Packets: {self.stats['packets_sent']} | PPS: {pps_actual:.1f}")

                # Check duration
                if duration > 0 and (time.time() - start_time) >= duration:
                    logger.info(f"Duration limit reached ({duration}s)")
                    break

        except KeyboardInterrupt:
            logger.info("\nStopping attack simulation...")
        finally:
            self.running = False
            self.print_statistics()

    def stop(self):
        """Stop attack simulation"""
        self.running = False


if __name__ == '__main__':
    logger.info("V2Ray Attack Simulator - AGGRESSIVE MODE")
    logger.info("WARNING: This generates malicious traffic patterns for testing ONLY")
    time.sleep(2)

    simulator = V2RayAttackSimulator()
    simulator.start()
